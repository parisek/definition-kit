#!/usr/bin/env php
<?php

declare(strict_types=1);

use Parisek\DefinitionKit\Migration\AcfJsonReader;
use Parisek\DefinitionKit\Migration\BlockResidualCapturer;
use Parisek\DefinitionKit\Migration\FieldsYamlWriter;

foreach ([__DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        break;
    }
}

/**
 * @return array{ok: bool, component: string, out?: string, error?: string}
 */
function fields_migrate_one(string $componentDir, bool $dryRun): array
{
    $componentDir = rtrim($componentDir, '/');
    $componentName = basename($componentDir);
    $acfPath = "{$componentDir}/acf.json";

    if (!is_file($acfPath)) {
        return ['ok' => false, 'component' => $componentName, 'error' => "no acf.json at {$acfPath}"];
    }

    $decoded = json_decode(file_get_contents($acfPath), true);
    if (!is_array($decoded)) {
        return ['ok' => false, 'component' => $componentName, 'error' => 'invalid JSON in acf.json'];
    }

    $twigPath = "{$componentDir}/{$componentName}.twig";
    $twigSource = is_file($twigPath) ? file_get_contents($twigPath) : null;

    try {
        $tree = (new AcfJsonReader())->read($decoded, $componentName, $twigSource);
    } catch (\Throwable $e) {
        // Broad on purpose: AbstractTypeMapper throws DomainException for an
        // unsupported ACF field type; a group/repeater with zero non-accordion
        // sub-fields throws RuntimeException. One bad component must be
        // reported and skipped, not abort the whole batch.
        return ['ok' => false, 'component' => $componentName, 'error' => $e->getMessage()];
    }

    // Capture the sibling block.json's non-derivable config (postTypes /
    // supports / attributes the generator can't reproduce) into root
    // `wp.block`, so block.json round-trips losslessly. Absent/invalid
    // block.json or an all-derivable one leaves the tree untouched.
    $blockPath = "{$componentDir}/block.json";
    if (is_file($blockPath)) {
        $blockDecoded = json_decode(file_get_contents($blockPath), true);
        if (is_array($blockDecoded)) {
            $wpBlock = (new BlockResidualCapturer())->capture($tree, $componentName, $blockDecoded);
            if ([] !== $wpBlock) {
                $tree['wp']['block'] = $wpBlock;
            }
        }
    }

    $outPath = $dryRun
        ? tempnam(sys_get_temp_dir(), 'fields-migrate-dry-run-')
        : "{$componentDir}/{$componentName}.yaml";

    try {
        (new FieldsYamlWriter())->write($tree, $outPath);
    } catch (\Throwable $e) {
        if ($dryRun) {
            @unlink($outPath);
        }
        return ['ok' => false, 'component' => $componentName, 'error' => $e->getMessage()];
    }

    if ($dryRun) {
        @unlink($outPath);
        return ['ok' => true, 'component' => $componentName];
    }

    return ['ok' => true, 'component' => $componentName, 'out' => $outPath];
}

$args = array_slice($argv, 1);
$root = null;
$dryRun = false;
$single = null;

foreach ($args as $arg) {
    if (str_starts_with($arg, '--root=')) {
        $root = substr($arg, 7);
        continue;
    }
    if ('--dry-run' === $arg) {
        $dryRun = true;
        continue;
    }
    $single = $arg;
}

if (null === $root && null === $single) {
    fwrite(STDERR, "usage: fields-migrate <component-dir> | fields-migrate --root=<components-root> [--dry-run]\n");
    exit(2);
}

if (null !== $root && !is_dir($root)) {
    fwrite(STDERR, "not a directory: {$root}\n");
    exit(2);
}

$results = [];
if (null !== $root) {
    $dirs = glob(rtrim($root, '/') . '/*', GLOB_ONLYDIR) ?: [];
    sort($dirs);
    foreach ($dirs as $dir) {
        if (is_file("{$dir}/acf.json")) {
            $results[] = fields_migrate_one($dir, $dryRun);
        }
    }
} else {
    $results[] = fields_migrate_one($single, $dryRun);
}

$failures = 0;
foreach ($results as $result) {
    if ($result['ok']) {
        echo "OK   {$result['component']}" . (isset($result['out']) ? " -> {$result['out']}" : '') . "\n";
        continue;
    }
    $failures++;
    echo "FAIL {$result['component']}: {$result['error']}\n";
}
echo sprintf("%d component(s), %d failed\n", count($results), $failures);

exit($failures > 0 ? 1 : 0);
